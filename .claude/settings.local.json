{
  "env": {
    "HQ_BYPASS_CORE_PROTECT": "1"
  },
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.gnupg/**)",
      "Read(~/.env)",
      "Read(~/.netrc)",
      "Read(~/.zshrc)",
      "Read(~/.zprofile)",
      "Read(~/.zshenv)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Edit(./companies/_template/**)",
      "Write(./companies/_template/**)"
    ]
  }
}
