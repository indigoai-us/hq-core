{
  "env": {
    "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-hq-glob $CLAUDE_PROJECT_DIR/.claude/hooks/block-hq-glob.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-hq-grep $CLAUDE_PROJECT_DIR/.claude/hooks/block-hq-grep.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh warn-cross-company-settings $CLAUDE_PROJECT_DIR/.claude/hooks/warn-cross-company-settings.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh detect-secrets $CLAUDE_PROJECT_DIR/.claude/hooks/detect-secrets.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-core-writes-bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-core-writes-bash.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-on-active-run $CLAUDE_PROJECT_DIR/.claude/hooks/block-on-active-run.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-policy-on-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/inject-policy-on-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-unsafe-package-install $CLAUDE_PROJECT_DIR/.claude/hooks/block-unsafe-package-install.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh protect-core $CLAUDE_PROJECT_DIR/.claude/hooks/protect-core.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-core-writes $CLAUDE_PROJECT_DIR/.claude/hooks/block-core-writes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-inline-story-impl $CLAUDE_PROJECT_DIR/.claude/hooks/block-inline-story-impl.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-on-active-run $CLAUDE_PROJECT_DIR/.claude/hooks/block-on-active-run.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh env-file-no-trailing-newline $CLAUDE_PROJECT_DIR/.claude/hooks/env-file-no-trailing-newline.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-policy-on-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/inject-policy-on-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-plans-dir-during-deep-plan $CLAUDE_PROJECT_DIR/.claude/hooks/block-plans-dir-during-deep-plan.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh protect-core $CLAUDE_PROJECT_DIR/.claude/hooks/protect-core.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-core-writes $CLAUDE_PROJECT_DIR/.claude/hooks/block-core-writes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-inline-story-impl $CLAUDE_PROJECT_DIR/.claude/hooks/block-inline-story-impl.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-on-active-run $CLAUDE_PROJECT_DIR/.claude/hooks/block-on-active-run.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh env-file-no-trailing-newline $CLAUDE_PROJECT_DIR/.claude/hooks/env-file-no-trailing-newline.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-policy-on-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/inject-policy-on-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh route-company-skill-creation $CLAUDE_PROJECT_DIR/.claude/hooks/route-company-skill-creation.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-plans-dir-during-deep-plan $CLAUDE_PROJECT_DIR/.claude/hooks/block-plans-dir-during-deep-plan.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-core-writes $CLAUDE_PROJECT_DIR/.claude/hooks/block-core-writes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-policy-on-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/inject-policy-on-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-plans-dir-during-deep-plan $CLAUDE_PROJECT_DIR/.claude/hooks/block-plans-dir-during-deep-plan.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh block-builtin-plan-mode-during-deep-plan $CLAUDE_PROJECT_DIR/.claude/hooks/block-builtin-plan-mode-during-deep-plan.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh PreToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh auto-checkpoint-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh screenshot-resize-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/screenshot-resize-trigger.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-due $CLAUDE_PROJECT_DIR/.claude/hooks/journal-due.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh auto-checkpoint-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh auto-mirror-company-skill $CLAUDE_PROJECT_DIR/.claude/hooks/auto-mirror-company-skill.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/master-sync.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-due $CLAUDE_PROJECT_DIR/.claude/hooks/journal-due.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh auto-checkpoint-trigger $CLAUDE_PROJECT_DIR/.claude/hooks/auto-checkpoint-trigger.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/master-sync.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-due $CLAUDE_PROJECT_DIR/.claude/hooks/journal-due.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-sync.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-due $CLAUDE_PROJECT_DIR/.claude/hooks/journal-due.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-autocapture $CLAUDE_PROJECT_DIR/.claude/hooks/journal-autocapture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-autocapture $CLAUDE_PROJECT_DIR/.claude/hooks/journal-autocapture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-autocapture $CLAUDE_PROJECT_DIR/.claude/hooks/journal-autocapture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-autocapture $CLAUDE_PROJECT_DIR/.claude/hooks/journal-autocapture.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh PostToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh precompact-thrashing-detector $CLAUDE_PROJECT_DIR/.claude/hooks/precompact-thrashing-detector.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh auto-checkpoint-precompact $CLAUDE_PROJECT_DIR/.claude/hooks/auto-checkpoint-precompact.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh journal-precompact $CLAUDE_PROJECT_DIR/.claude/hooks/journal-precompact.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh PreCompact",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh observe-patterns $CLAUDE_PROJECT_DIR/.claude/hooks/observe-patterns.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh cleanup-mcp-processes $CLAUDE_PROJECT_DIR/.claude/hooks/cleanup-mcp-processes.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh context-warning-50 $CLAUDE_PROJECT_DIR/.claude/hooks/context-warning-50.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh capture-estimates $CLAUDE_PROJECT_DIR/.claude/hooks/capture-estimates.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh Stop",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-sync.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh load-policies $CLAUDE_PROJECT_DIR/.claude/hooks/load-policies-for-session.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh check-bridge-health $CLAUDE_PROJECT_DIR/.claude/hooks/check-claude-desktop-bridge-health.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh check-repo-active-runs $CLAUDE_PROJECT_DIR/.claude/hooks/check-repo-active-runs.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh inject-local-context $CLAUDE_PROJECT_DIR/.claude/hooks/inject-local-context.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh check-core-yaml-parity $CLAUDE_PROJECT_DIR/.claude/hooks/check-core-yaml-parity.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh load-journal-index-on-start $CLAUDE_PROJECT_DIR/.claude/hooks/load-journal-index-on-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh SessionStart",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh rewrite-resume-sentinel $CLAUDE_PROJECT_DIR/.claude/hooks/rewrite-resume-sentinel.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/hook-gate.sh route-deep-plan-to-skill $CLAUDE_PROJECT_DIR/.claude/hooks/route-deep-plan-to-skill.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh UserPromptSubmit",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh Notification",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh SubagentStop",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/master-hook.sh SessionEnd",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory"
}
