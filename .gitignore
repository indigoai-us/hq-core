# Credentials and secrets
settings/**/*.json
!settings/.gitkeep
!settings/pure-ralph.json
*.credentials.json
*.secret.*
.mcp.json
# ...but plugin packs MUST ship their `.mcp.json` — it is the manifest that
# registers the pack's MCP server with Claude Code / Cowork. Without it the
# host loads zero tools (feedback_ce873c1f). These manifests carry no secrets.
!core/packages/*/.mcp.json
.env.*-token

# Environment files
.env
.env.local
.env.*.local
workspace/charlie-envs/

# Cloned repos (independent git repos, symlinked into HQ).
# Root-anchored (`/repos/`) so ONLY the top-level clone dir is excluded. A bare
# `repos/` matches a directory named `repos` at ANY depth, which silently drops
# legitimate nested content such as companies/<co>/knowledge/repos/<name>/
# (discover-generated knowledge) from cloud sync — this file is merged into the
# sync ignore filter as a layer. See DEV-1791.
/repos/

# Node
node_modules/
dist/
build/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS files
.DS_Store
Thumbs.db

# Editor files
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.scratch/

# Generated digests (keep structure, not content)
workspace/digests/*.html
workspace/digests/*.md

# Draft content (personal)
social-content/drafts/**/*.md
!social-content/drafts/INDEX.md

# Checkpoints (session-specific)
workspace/checkpoints/*.json

# Journal entries (personal)
data/journal/*.jsonl

# Synced modules (cloned repos)
modules/.synced/
!.claude/settings.local.json
.vercel
.env*.local

# Defense-in-depth: any *.env file under company settings (covers names that
# don't start with `.env`, e.g. coding-agent.env). The .env*.local pattern
# above only matches files that BEGIN with .env — so a bare `coding-agent.env`
# would slip through if a future Claude or human placed credentials there.
companies/*/settings/*.env
companies/*/settings/*.env.*
companies/*/settings/secrets/

# Work Mesh transcript staging (company-work-corpus US-004). Full-content,
# tenant-scoped session transcripts copied here by the close hook must NEVER
# enter HQ-root git history — they are locally-staged for hq-sync only. Excluded
# from autocommit (respects gitignore) and from qmd/Grep (see .ignore).
companies/*/sessions/

# Obsidian runtime (keep shipped config, ignore personal state)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/community-plugins.json

# Added by ggshield
.cache_ggshield

# Ephemeral hook state (per-session, 0-byte touch files)
workspace/.context-warnings/

# hq-kit-app engine state (SQLite WAL, release tarball cache, engine logs).
# Belt-and-suspenders: the /repos/ line above already excludes the whole clone,
# but hq-kit-app is referenced enough in HQ flows (orchestrator, /kit) that
# calling out .data/ here prevents accidental `git add -f` mistakes.
repos/private/hq-kit-app/.data/

# Build artifacts / caches that should never be committed
.next/
.nx/
test-results/

# rtk (Rust Token Killer) trial — root CLAUDE.md is rtk's legacy-mode
# instruction file (rtk init regenerates it), we don't want it tracked.
# .rtk/ is rtk's project-filter dir; we re-enable + commit if we adopt
# custom filters during the trial.
/CLAUDE.md
.rtk/

# Local VS Code launch config (may contain inline secrets — keep ignored)
.claude/launch.json
